---
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="icon" href="/favicon.ico" />
    <title>John Trager</title>
    <style>
		@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

		:root {
		  --bg: #fdf6e3;
		  --fg: #333333;
		  --accent: #007acc;
		  --heading: #111111;
		  --muted: #666666;
		  --border: #e0dbc8;
		}

		body {
		  margin: 0;
		  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
		  background-color: var(--bg);
		  color: var(--fg);
		  line-height: 1.8;
		  display: flex;
		  flex-direction: column;
		  min-height: 100vh;
		}

		main {
		  max-width: 750px;
		  margin: 0 auto;
		  padding: 4rem 2rem;
		  flex: 1;
		}

		h1 {
		  font-size: 2.8rem;
		  color: var(--heading);
		  margin-bottom: 0.5rem;
		  font-weight: 600;
		}

		h2 {
		  font-size: 1.8rem;
		  color: var(--heading);
		  border-bottom: 1px solid var(--border);
		  padding-bottom: 0.3rem;
		  margin-top: 3rem;
		  margin-bottom: 1rem;
		  font-weight: 500;
		}

		p, li {
		  font-size: 1.1rem;
		  color: var(--fg);
		}

		a {
		  color: var(--accent);
		  text-decoration: underline;
		}

		a:hover {
		  text-decoration: none;
		}

		.section {
		  margin-bottom: 2.5rem;
		}

		ul {
		  padding-left: 1.5rem;
		}

		li {
		  margin-bottom: 0.8rem;
		}

		.highlight {
		  font-weight: 600;
		  color: var(--accent);
		}

		footer {
		  text-align: center;
		  padding: 2rem;
		  font-size: 0.95rem;
		  color: var(--muted);
		  border-top: 1px solid var(--border);
		}

		@media (max-width: 600px) {
		  h1 {
			font-size: 2.2rem;
		  }

		  h2 {
			font-size: 1.6rem;
		  }

		  p, li {
			font-size: 1rem;
		  }
		}
	</style>
  </head>
  <body>
    <main>
      <section class="section">
        <h1>Hi, I'm <span class="highlight">John Trager</span> 👋</h1>
        <p>I am really awesome, and so is Ariel!</p>
      </section>

      <section class="section">
        <h2>About Me</h2>
        <p>
          I am a software engineer who mostly works on system level programming but also dabbles in basically everything...
        </p>
      </section>

      <section class="section">
        <h2>Projects</h2>
        <ul>
          <li><span class="highlight">TODO</span>: well not an actual project I need to update this!</li>
        </ul>
      </section>

      <section class="section">
        <h2>Contact</h2>
        <p>
          You can reach me on <a href="https://www.linkedin.com/in/john-trager/">linkedin</a> or
          check out my work on <a href="https://github.com/john-trager" target="_blank">GitHub</a>.
        </p>
      </section>
    </main>
	<footer>
		Made with ❤️ in NYC — © 2025 John Trager
	</footer>
  </body>
</html>
