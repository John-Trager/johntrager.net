---
const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<!-- SEO -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="John Trager" />
		<!-- Open Graph / etc -->
		<meta property="og:title" content={title} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://johntrager.net" />
		<link rel="canonical" href="https://johntrager.net" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<!-- SEO END -->

		<link rel="icon" href="/favicon.ico" />

		<!-- Fonts and Styles -->
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
		/>
		<!-- Global Styles -->
		<style is:global>
			@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');
	
			:root {
			  --bg: #fdf6e3;
			  --fg: #333333;
			  --accent: #007acc;
			  --heading: #111111;
			  --muted: #666666;
			  --border: #e0dbc8;
			}
	
			body {
			  margin: 0;
			  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
			  background-color: var(--bg);
			  color: var(--fg);
			  line-height: 1.8;
			  display: flex;
			  flex-direction: column;
			  min-height: 100vh;
			}
	
			main {
			  max-width: 750px;
			  margin: 0 auto;
			  padding: 4rem 2rem;
			  flex: 1;
			}
	
			h1 {
			  font-size: 2.8rem;
			  color: var(--heading);
			  margin-bottom: 0.5rem;
			  font-weight: 600;
			}
	
			h2 {
			  font-size: 1.8rem;
			  color: var(--heading);
			  border-bottom: 1px solid var(--border);
			  padding-bottom: 0.3rem;
			  margin-top: 3rem;
			  margin-bottom: 1rem;
			  font-weight: 500;
			}
	
			p, li {
			  font-size: 1.1rem;
			  color: var(--fg);
			}
	
			a {
			  color: var(--accent);
			  text-decoration: underline;
			}
	
			a:hover {
			  text-decoration: none;
			}
	
			.section {
			  margin-bottom: 2.5rem;
			}
	
			ul {
			  padding-left: 1.5rem;
			}
	
			li {
			  margin-bottom: 0.8rem;
			}
	
			.highlight {
			  font-weight: 600;
			  color: var(--accent);
			}
	
			footer {
			  text-align: center;
			  padding: 2rem;
			  font-size: 0.95rem;
			  color: var(--muted);
			  border-top: 1px solid var(--border);
			}
	
			@media (max-width: 600px) {
			  h1 {
				font-size: 2.2rem;
			  }
	
			  h2 {
				font-size: 1.6rem;
			  }
	
			  p, li {
				font-size: 1rem;
			  }
			}
		</style>
		<!-- Allow additional elements to be injected from pages -->
		<slot name="head" />
	</head>
	<body>
		<main>
			<slot />
		</main>
		<footer>Made with ❤️ in NYC — © 2025 John Trager</footer>
	</body>
</html>
